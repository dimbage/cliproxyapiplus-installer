# Show logs
show_logs() {
    if ! systemctl --user is-enabled --quiet "${SERVICE_NAME}" 2>/dev/null && \
       ! is_service_running; then
        log_warning "Service is not installed or not running"
        log_info "You can still check with: journalctl --user -u ${SERVICE_NAME}"
    fi

    log_info "Showing ${DISPLAY_NAME} service logs (last 50 lines)..."
    echo
    journalctl --user -u "${SERVICE_NAME}" -n 50 --no-pager 2>/dev/null || \
        log_warning "Could not retrieve logs. Make sure the service has been started at least once."
}

# Main entry point
main() {
    local command="${1:-help}"

    case "$command" in
        install|update|upgrade)
            install_cliproxyapi
            ;;
        uninstall|remove)
            uninstall_cliproxyapi
            ;;
        status|info)
            show_status
            ;;
        start)
            start_service
            ;;
        stop)
            stop_service
            ;;
        restart)
            restart_service
            ;;
        logs|log)
            show_logs
            ;;
        docs|documentation)
            manage_documentation
            ;;
        auth|authentication|login)
            show_authentication_info
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "Unknown command: $command"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
